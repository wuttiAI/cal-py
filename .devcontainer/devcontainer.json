{
    "name": "Python Tkinter Sandbox",
    "image": "mcr.microsoft.com/devcontainers/universal:2",
    "features": {
        "ghcr.io/devcontainers/features/desktop-gui:1": {
            "version": "latest"
        }
    },
    "forwardPorts": [6080],
    "portsAttributes": {
        "6080": {
            "label": "เปิดหน้าต่าง GUI (noVNC)",
            "onAutoForward": "openPreview"
        }
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y python3-tk"
}
